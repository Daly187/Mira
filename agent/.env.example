# ═══════════════════════════════════════════════════════════════
# MIRA — Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to any repository
# ═══════════════════════════════════════════════════════════════

# ── Core API Keys ────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Claude Settings — Tiered Models ──────────────────────────
# Fast (Haiku): JSON extraction, classification — cheapest
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001
# Standard (Sonnet): Conversation, analysis, drafting — balanced
CLAUDE_MODEL_STANDARD=claude-sonnet-4-5-20250929
# Deep (Opus): Research, decisions, complex reasoning — best
CLAUDE_MODEL_DEEP=claude-opus-4-5-20251101
CLAUDE_MAX_TOKENS=4096

# ── Agent Behaviour ──────────────────────────────────────────
TICK_INTERVAL=5
TIMEZONE=Asia/Manila

# ── Daily Briefing ───────────────────────────────────────────
BRIEFING_TIME=07:00
BRIEFING_TIMEZONE=Asia/Manila

# ── Trading Risk Limits ──────────────────────────────────────
MAX_DAILY_DRAWDOWN_PCT=3.0
MAX_POSITION_SIZE=0.1
MAX_TOTAL_EXPOSURE=5.0

# ── Local Model (Optional — On-Device AI) ────────────────────
# Runs simple tasks locally for free before using paid Claude API.
# Install Ollama: https://ollama.com/download (Windows installer)
# Then run: ollama pull phi3:mini
# Set LOCAL_MODEL_ENABLED=true to activate
LOCAL_MODEL_ENABLED=false
LOCAL_MODEL_URL=http://localhost:11434
LOCAL_MODEL_NAME=phi3:mini
LOCAL_MODEL_MAX_TOKENS=1024
LOCAL_MODEL_TIMEOUT=30

# ── Web Access ───────────────────────────────────────────────
# API token for remote dashboard access (set a strong random string)
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_TOKEN=
# 6-digit PIN for dashboard login (extra security layer, verified client-side)
# Set any 6-digit number. The SHA-256 hash is hardcoded in the dashboard.
DASHBOARD_PIN=
WEB_HOST=0.0.0.0
WEB_PORT=8000

# ── Telegram Userbot (Telethon) ──────────────────────────────
# Required for autonomous Telegram conversation management.
# Get API ID and Hash from: https://my.telegram.org → API development tools
TG_API_ID=
TG_API_HASH=
TG_PHONE=                 # Your phone number with country code, e.g. +639171234567
TG_SYNC_INTERVAL=300      # Seconds between conversation syncs (default 5 min)

# ── Privacy ──────────────────────────────────────────────────
ENCRYPT_AT_REST=true

# ── PA Module — Priority Senders ──────────────────────────────
# Comma-separated email addresses/domains whose calendar invites
# get special treatment (evaluated by AI instead of auto-declined outside work hours)
# PRIORITY_SENDERS=boss@company.com,important@client.com

# ── Google APIs (Phase 6) ────────────────────────────────────
# Download OAuth 2.0 credentials from Google Cloud Console and save as:
#   agent/data/google_credentials.json
# Then run: python -m helpers.google_auth   (one-time interactive setup)
# GOOGLE_CREDENTIALS_PATH=data/google_credentials.json

# ── MT5 (Phase 7) ────────────────────────────────────────────
# MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# ── ElevenLabs Voice (Phase 11) ──────────────────────────────
# ELEVENLABS_API_KEY=your_key_here
# ELEVENLABS_VOICE_ID=your_voice_id_here
